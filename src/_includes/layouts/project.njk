---
layout: layouts/base.njk
ogType: article
eleventyComputed:
  bodyClass: "wp-singular project-template-default single single-project {{ project.slug }}"
  title: "{{ project.title }}"
  description: "{{ project.description }}"
  ogImage: "/{{ project.hero }}"
  ogImageWidth: "{{ project.heroWidth }}"
  ogImageHeight: "{{ project.heroHeight }}"
---
{%- set heroAlt -%}{{ project.title }}{% if project.location %} — {{ project.location }}{% elif project.subtitle %} — {{ project.subtitle }}{% endif %}{%- endset -%}
{%- set contextAlt -%}{{ project.title }}{% if project.location %}, {{ project.location }}{% endif %}{%- endset -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": {{ project.title | dump | safe }},
  "url": "{{ site.url }}{{ page.url | url }}",
  "description": {{ (project.description or '') | dump | safe }},
  {% if project.date %}"datePublished": "{{ project.date }}",{% endif %}
  "image": {
    "@type": "ImageObject",
    "url": "{{ site.url }}{{ ('/' + project.hero) | url }}"
    {% if project.heroWidth %},"width": {{ project.heroWidth }}{% endif %}
    {% if project.heroHeight %},"height": {{ project.heroHeight }}{% endif %}
  },
  "creator": { "@id": "{{ site.url }}/#organization" },
  "inLanguage": "{{ site.lang }}"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}{{ '/' | url }}" },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": "{{ site.url }}{{ '/projects/' | url }}" },
    { "@type": "ListItem", "position": 3, "name": {{ project.title | dump | safe }} }
  ]
}
</script>

<section id="content">
  <article class="project type-project status-publish has-post-thumbnail hentry">
    <div class="entry-content">
      <div class="wpb-content-wrapper">

        <section class="section header-hero header-full-image position-relative bg-image pt-0 pt-lg-0 mb-36 mb-lg-72">
          <div class="background-image d-flex align-items-center gradient gradient-up-dark z-index-1 p-0" data-vertical="center" data-horizontal="center">
            <div class="image">
              <picture>
                <source srcset="{{ ('/' + project.hero + '.webp') | url }}" type="image/webp">
                <img fetchpriority="high" decoding="async"
                  src="{{ ('/' + project.hero) | url }}"
                  alt="{{ heroAlt }}"
                  {% if project.heroWidth %}width="{{ project.heroWidth }}"{% endif %}
                  {% if project.heroHeight %}height="{{ project.heroHeight }}"{% endif %}
                  class="attachment-full size-full">
              </picture>
            </div>
          </div>
          <div class="container d-flex align-items-center justify-content-start h-high position-relative z-index-3 py-96">
            <div class="row flex-column flex-lg-row align-items-center justify-content-start position-relative d-flex">
              <div class="col-12 col-lg-12 align-items-start justify-content-start d-flex flex-column flex-wrap text-white text-start">
                <h1 class="h1 lh-xl fw-light ff-secondary mb-16 text-white">{{ project.title }}</h1>
                {% if project.subtitle %}
                <div class="text-lg ff-primary fw-light lh-xl text w-lg-60">{{ project.subtitle }}</div>
                {% endif %}
              </div>
            </div>
          </div>
        </section>

        {% if project.location %}
        <section class="section section-header text-start pt-0 pt-lg-0 pb-16 pb-lg-16">
          <div class="container">
            <div class="col-12">
              <h2 class="h4 lh-xl fw-light ff-secondary title text-black mb-0">{{ project.location }}</h2>
            </div>
          </div>
        </section>
        {% endif %}

        {% if project.paragraphs and project.paragraphs.length %}
        <section class="section text-element pt-0 pt-lg-0 pb-36 pb-lg-72">
          <div class="container">
            <div class="col-12 col-xl-10">
              <div class="text-normal ff-primary fw-light lh-xl text-start content text-black">
                {% for p in project.paragraphs %}<p>{{ p }}</p>{% endfor %}
              </div>
            </div>
          </div>
        </section>
        {% endif %}

        {% if project.images and project.images.length %}
        <section class="section section-gallery pt-0 pt-lg-0 pb-72 pb-lg-120">
          <div class="container">
            <div class="row gx-16 gy-16">
              {% for img in project.images %}
              <div class="col-12 col-md-6">
                <figure class="m-0">
                  <picture>
                    <source srcset="{{ ('/' + img.url + '.webp') | url }}" type="image/webp">
                    <img
                      src="{{ ('/' + img.url) | url }}"
                      alt="{{ contextAlt }} — image {{ loop.index }} of {{ project.images.length }}"
                      {% if img.width %}width="{{ img.width }}"{% endif %}
                      {% if img.height %}height="{{ img.height }}"{% endif %}
                      loading="lazy"
                      decoding="async"
                      class="w-100 h-auto">
                  </picture>
                </figure>
              </div>
              {% endfor %}
            </div>
          </div>
        </section>
        {% endif %}

      </div>
    </div>
  </article>
</section>
